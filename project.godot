[configuration]

config_version=5

[application]

config/name="Vertical Abyss"
config/description="垂直深渊 | Vertical Abyss — A roguelite survival game"
config/features=PackedStringArray("4.6", "Web")
config/icon="res://icon.svg"

[autoload]

RunStateManager="*res://src/core/run_state_manager.gd"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
